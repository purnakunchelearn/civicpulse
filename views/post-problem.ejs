<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post a Problem | Problem Tracker</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0f172a !important;
            /* var(--bg-color) */
            color: #f8fafc !important;
            /* var(--text-main) */
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
        }

        .top-nav-bar {
            background: linear-gradient(90deg, #7c3aed, #6366f1);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
        }

        .top-nav-bar .logo {
            font-size: 1.25rem;
            font-weight: 700;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            align-items: center;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-size: 0.95rem;
        }

        .nav-links span {
            font-size: 0.95rem;
        }

        .dashboard-content {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
        }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            margin-top: 1rem;
        }

        .dashboard-title {
            font-size: 2rem;
            font-weight: 700;
            color: #f8fafc;
            margin: 0;
        }

        .btn-secondary {
            background: transparent;
            color: #f8fafc;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.2s;
            border: 1px solid #334155;
            cursor: pointer;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: #94a3b8;
        }

        .post-problem-form {
            background: #1e293b;
            border-radius: 12px;
            border: 1px solid #334155;
            padding: 2.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.75rem;
            font-weight: 600;
            color: #94a3b8;
        }

        .form-group input[type="text"],
        .form-group textarea,
        .form-group input[type="file"] {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #334155;
            border-radius: 6px;
            font-size: 1rem;
            box-sizing: border-box;
            background: #0f172a;
            color: #f8fafc;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
            background: #0f172a;
        }

        .btn-primary {
            background-color: #6366f1;
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1rem;
            transition: background 0.2s;
            width: 100%;
        }

        .btn-primary:hover {
            background-color: #4f46e5;
        }

        .btn-location {
            background: transparent;
            color: #f8fafc;
            border: 1px solid #334155;
            padding: 0.75rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: all 0.2s;
        }

        .btn-location:hover,
        .btn-generate:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: #94a3b8;
        }

        .btn-generate {
            background: transparent;
            color: #10b981;
            border: 1px solid #10b981;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: all 0.2s;
            margin-top: 0.5rem;
            width: fit-content;
        }

        .btn-generate:hover {
            background: rgba(16, 185, 129, 0.1);
            border-color: #059669;
        }

        .btn-generate.loading {
            opacity: 0.7;
            cursor: not-allowed;
            color: #94a3b8;
            border-color: #334155;
        }
    </style>
</head>

<body>
    <div class="top-nav-bar">
        <div class="logo">CivicPulse</div>
        <div class="nav-links">
            <span>Welcome, <%= locals.user ? user.username : 'tester' %></span>
            <a href="/user-dashboard">My Problems</a>
            <a href="/user-logout">Logout</a>
        </div>
    </div>

    <div class="dashboard-content">
        <div class="dashboard-header">
            <h1 class="dashboard-title">Report a New Problem</h1>
            <a href="/user-dashboard" class="btn-secondary">Back to Dashboard</a>
        </div>

        <div class="post-problem-form">
            <form action="/post-problem" method="POST" enctype="multipart/form-data">


                <div class="form-group">
                    <label for="name">Problem Name (Optional)</label>
                    <input type="text" id="name" name="name" placeholder="Leave blank to auto-generate from image">
                </div>

                <div class="form-group">
                    <label for="image">Upload Image</label>
                    <input type="file" id="image" name="image" accept="image/*" required>
                    <button type="button" class="btn-generate" id="btnGenerateAI" style="display: none;">
                        ✨ Auto-Generate Name & Description
                    </button>
                    <small id="aiStatus"
                        style="color: #6b7280; display: block; margin-top: 0.5rem; font-size: 0.85rem;"></small>
                </div>

                <div class="form-group">
                    <label for="location">Location</label>
                    <button type="button" class="btn-location" id="getLocationBtn"
                        style="margin-bottom: 0.75rem; width: 100%;">
                        <span>📍 Use Current Location</span>
                    </button>
                    <input type="text" id="location" name="location" placeholder="Or enter address manually here..."
                        required>
                    <small id="locationStatus"
                        style="color: #6b7280; display: block; margin-top: 0.75rem; font-size: 0.85rem;"></small>
                </div>




                <div class="form-group">
                    <label for="description">Detailed Description (Optional)</label>
                    <textarea id="description" name="description" rows="3"
                        placeholder="Leave blank to auto-generate from image"></textarea>
                </div>

                <button type="submit" class="btn-primary" style="margin-top: 1rem;">Post Problem</button>
            </form>
        </div>
    </div>

    <script>
        // AI Generation Logic
        const imageInput = document.getElementById('image');
        const btnGenerateAI = document.getElementById('btnGenerateAI');
        const aiStatus = document.getElementById('aiStatus');
        const nameInput = document.getElementById('name');
        const descInput = document.getElementById('description');

        // Show generate button only when an image is selected
        imageInput.addEventListener('change', () => {
            if (imageInput.files && imageInput.files.length > 0) {
                btnGenerateAI.style.display = 'flex';
                aiStatus.textContent = '';
            } else {
                btnGenerateAI.style.display = 'none';
            }
        });

        btnGenerateAI.addEventListener('click', async () => {
            if (!imageInput.files || imageInput.files.length === 0) return;

            const file = imageInput.files[0];
            const formData = new FormData();
            formData.append('image', file);

            btnGenerateAI.disabled = true;
            btnGenerateAI.classList.add('loading');
            btnGenerateAI.innerHTML = '⏳ Analyzing Image...';
            aiStatus.textContent = '';

            try {
                const response = await fetch('/api/generate-description', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    nameInput.value = data.name;
                    descInput.value = data.description;
                    aiStatus.textContent = '✅ Successfully generated!';
                    aiStatus.style.color = '#10b981';
                } else {
                    aiStatus.textContent = '❌ ' + (data.error || 'Failed to generate.');
                    aiStatus.style.color = '#ef4444';
                }
            } catch (err) {
                aiStatus.textContent = '❌ Network error during generation.';
                aiStatus.style.color = '#ef4444';
            } finally {
                btnGenerateAI.disabled = false;
                btnGenerateAI.classList.remove('loading');
                btnGenerateAI.innerHTML = '✨ Auto-Generate Name & Description';
            }
        });

        // Geolocation Logic
        document.getElementById('getLocationBtn').addEventListener('click', function () {
            const locationInput = document.getElementById('location');
            const statusText = document.getElementById('locationStatus');
            const btn = this;

            if (!navigator.geolocation) {
                statusText.textContent = 'Geolocation is not supported by your browser';
                statusText.style.color = '#ef4444';
                return;
            }

            statusText.textContent = 'Locating...';
            statusText.style.color = '#6b7280';
            btn.disabled = true;
            btn.style.opacity = '0.7';
            btn.innerHTML = '<span>⏳ Locating...</span>';

            navigator.geolocation.getCurrentPosition(
                async (position) => {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;

                    try {
                        const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`);
                        const data = await response.json();

                        if (data && data.display_name) {
                            locationInput.value = data.display_name;
                            statusText.textContent = 'Location successfully found!';
                            statusText.style.color = '#10b981';
                        } else {
                            locationInput.value = `${lat}, ${lng}`;
                            statusText.textContent = 'Coordinates found!';
                            statusText.style.color = '#10b981';
                        }
                    } catch (error) {
                        locationInput.value = `${lat}, ${lng}`;
                        statusText.textContent = 'Coordinates found (address lookup failed)';
                        statusText.style.color = '#f59e0b';
                    }

                    btn.disabled = false;
                    btn.style.opacity = '1';
                    btn.innerHTML = '<span>📍 Use Current Location</span>';
                },
                (error) => {
                    let errorMessage = 'Unable to retrieve your location.';
                    switch (error.code) {
                        case error.PERMISSION_DENIED:
                            errorMessage = 'Location access denied. Please enter it manually below.'
                            break;
                        case error.POSITION_UNAVAILABLE:
                            errorMessage = 'Location information is unavailable. Please enter it manually below.'
                            break;
                        case error.TIMEOUT:
                            errorMessage = 'The request timed out. Please enter it manually below.'
                            break;
                    }
                    statusText.textContent = errorMessage;
                    statusText.style.color = '#f59e0b';
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    btn.innerHTML = '<span>📍 Try Again</span>';
                }
            );
        });
    </script>
</body>

</html>